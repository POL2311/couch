{
  "expo": {
    "name": "MyCoach",
    "slug": "mycoach-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "mycoach",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0a0a0b",
    "splash": {
      "backgroundColor": "#0a0a0b",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mycoach.mobile",
      "infoPlist": {
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "package": "com.mycoach.mobile",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0b"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "MyCoach usa tu ubicación para registrar el recorrido de tus carreras."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "MyCoach usa la cámara para tomar la foto de fondo al compartir tu carrera."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MyCoach accede a tu galería para elegir la foto de fondo al compartir tu carrera."
        }
      ],
      [
        "expo-media-library",
        {
          "savePhotosPermission": "MyCoach guarda la imagen de tu carrera en tu galería.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
