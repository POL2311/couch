# Copia este archivo a `.env` y ajusta los valores.

# Base de datos — PostgreSQL para producción (Neon / Vercel Postgres / Supabase / Railway)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
# Si usas pooler de Neon, añade también:
# DIRECT_URL="postgresql://USER:PASSWORD@HOST_DIRECT/DATABASE?sslmode=require"

# SQLite para desarrollo local sin conexión a la nube:
# DATABASE_URL="file:./dev.db"

# NextAuth / Auth.js — genera un secreto con: npx auth secret
AUTH_SECRET="cambia-esto-por-un-secreto-seguro"
AUTH_TRUST_HOST=true

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# URL base de la app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
