# Copia este archivo a `.env` y ajusta los valores.

# ── Base de datos (Neon PostgreSQL) ──────────────────────────────────────────
# DATABASE_URL  → connection pooler endpoint (PgBouncer, puerto 6543)
#                  Usado por Prisma Client en runtime para todas las queries.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.pooler.us-east-1.aws.neon.tech:6543/neondb?sslmode=require&pgbouncer=true"

# DIRECT_URL    → direct (unpooled) endpoint (puerto 5432)
#                  Usado exclusivamente por prisma migrate / db push para DDL.
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-1.aws.neon.tech:5432/neondb?sslmode=require"

# ── NextAuth / Auth.js ────────────────────────────────────────────────────────
# Genera un secreto con: npx auth secret
AUTH_SECRET="cambia-esto-por-un-secreto-seguro"
AUTH_TRUST_HOST=true

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── URL base de la app ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://tu-dominio.vercel.app"
